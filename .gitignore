# ---- Build output ----
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
*.user
*.suo

# ---- Visual Studio ----
.vs/
*.userprefs

# ---- Local development beta (per project rule: ignored) ----
/BETA_1/

# ============================================================
#  PRIVACY: never commit anyone's mail, credentials or indexes.
#  These are produced at runtime under the configured archive
#  paths and inside Resources at dev time. Keep them out of git.
# ============================================================

# DPAPI-protected configs and per-account state
Resources/Configurations/*.json
!Resources/Configurations/configuration_template.json
*.manifest.json
*.verification.json
*.journal.log
*.failures.log

# Archived mail, attachments and search indexes (sample + real)
Resources/ARCHIVES/
**/ARCHIVES/
**/INDEX/
**/ATTACHMENTS/

# OS cruft
Thumbs.db
desktop.ini
.DS_Store
